          "name": "Send Authenticated JSON-RPC Relay",
          "request": {
            "name": "Send Authenticated JSON-RPC Relay",
            "description": {
              "content": "Send a JSON-RPC payload for the configured service through a Grove portal application. The path segment `appId` is the Grove portal Application ID returned by the dashboard; the subdomain selects the chain (e.g. `eth.rpc.grove.city`). The request body is the standard JSON-RPC 2.0 envelope of the target chain — PATH does not rewrite it.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                ":appId"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "appId",
                  "description": "(Required) Grove portal Application ID (alphanumeric)."
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "Override the service-id derived from the subdomain. Used when self-hosting PATH behind a single hostname.\n",
                "key": "Target-Service-Id",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
